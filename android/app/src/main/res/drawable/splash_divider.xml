<?xml version="1.0" encoding="utf-8"?>
<!-- 装饰线：1dp 高的水平线，两端渐隐 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/splash_divider_edge"
        android:centerColor="@color/splash_divider_center"
        android:endColor="@color/splash_divider_edge" />
    <size android:height="1dp" />
</shape>

