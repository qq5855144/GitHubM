<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      不使用透明状态栏 + 边到边模式：
      WebView 内容无法像原生 View 精确响应 insets，透明模式会导致内容被状态栏覆盖。
      改为纯色状态栏（与 App 背景同色），Android 系统自动将内容放置在状态栏下方。
    -->
    <style name="Theme.GitHubManager" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- 窗口背景与 App 深色背景一致，防止冷启动闪白 -->
        <item name="android:windowBackground">#0d1117</item>
        <!-- 状态栏颜色由 MainActivity 代码设置，此处设为与背景一致的默认值 -->
        <item name="android:statusBarColor">#0d1117</item>
        <item name="android:navigationBarColor">#161b22</item>
        <!-- API 28+ 刘海屏延伸；低版本自动忽略 -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- Material 组件主题色 -->
        <item name="colorPrimary">#7c3aed</item>
        <item name="colorPrimaryVariant">#6d28d9</item>
        <item name="colorOnPrimary">#ffffff</item>
    </style>

    <!-- 底部导航栏选中文字样式 -->
    <style name="BottomNavTextActive">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- 底部导航栏未选中文字样式 -->
    <style name="BottomNavTextInactive">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>
