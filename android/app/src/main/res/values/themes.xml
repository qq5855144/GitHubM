<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      使用 Theme.Material3（material 1.12.0 的默认主题基础）。
      statusBarColor / navigationBarColor 已在 API 35 废弃，
      统一由 MainActivity 通过 WindowInsetsControllerCompat 控制。
    -->
    <style name="Theme.GitHubManager" parent="Theme.Material3.Light.NoActionBar">
        <!--
          冷启动窗口背景：与浅色模式启动画面背景色一致，避免白屏闪烁。
          使用颜色资源（@color/splash_bg_solid），values-night 自动切换。
        -->
        <item name="android:windowBackground">@color/splash_bg_solid</item>
        <!-- API 28+ 刘海屏延伸；低版本自动忽略 -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- Material3 主题色 -->
        <item name="colorPrimary">#7c3aed</item>
        <item name="colorPrimaryVariant">#6d28d9</item>
        <item name="colorOnPrimary">#ffffff</item>
        <!-- M3 Active Indicator 填充色（BottomNav 选中指示器背景）：浅紫 -->
        <item name="colorSecondaryContainer">#EDE9FE</item>
        <item name="colorOnSecondaryContainer">#5B21B6</item>
    </style>

    <!--
      ══ 底部导航栏 M3 样式 ══════════════════════════════════════════

      BottomNavTextActive / BottomNavTextInactive
        紧凑规格：10sp，图标与文字间距更小，整体高度更紧凑。
        选中与未选中使用相同字号，靠颜色区分；选中加粗增强层次感。
    -->
    <!--
      兼容性修复：
      - 继承 TextAppearance.Material3.LabelSmall，确保 Material3 BottomNavigationView
        在所有 API 级别和 OEM ROM 上都能正确初始化 label 布局
      - 移除 android:fontFamily="sans-serif-medium"：该值在小米 MIUI / OPPO ColorOS /
        魅族 Flyme 等 ROM 上字体映射缺失，Typeface 加载失败后 Material 库静默捕获异常，
        标签文字完全不渲染；改用 android:textStyle="bold" 实现加粗，通用兼容
      - 移除 android:fontFamily="sans-serif"：已是系统默认，在部分 OEM 自定义字体
        替换流程中反而干扰正常渲染
      - 移除 android:letterSpacing：在某些 OEM 设备低版本渲染路径上触发异常，
        导致整个 TextAppearance 回退、标签消失
    -->
    <style name="BottomNavTextActive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!--
      BottomNavActiveIndicator
        Active Indicator 设为透明：选中状态仅通过图标/文字强调色区分，
        不显示胶囊背景；点击涟漪覆盖整个 item 区域（图标+文字视为整体）。
        尺寸保留（运行时颜色由 applyNativeTheme 设为透明）。
    -->
    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">48dp</item>
        <item name="android:height">24dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
    </style>

</resources>
